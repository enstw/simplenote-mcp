# Simplenote API token (obtain once with `sn auth login` / `sn auth token`
# from ../simplenote-sync, or via the Simperium authorize endpoint).
# The password is never needed here — only the token.
SIMPLENOTE_TOKEN=

# Tag that scopes which notes belong to this Claude project. Every file the
# connector reads/writes carries this tag, isolating one project's notes from
# the rest of the Simplenote account.
SIMPLENOTE_PROJECT_TAG=claude-project-default

# Transport: "stdio" for local/desktop testing, "http" (streamable-http) for a
# remote connector that Claude.ai web chat can attach to.
MCP_TRANSPORT=stdio
